{
  "Type": "Generic",
  "Parameters": {
    "NameTranslationKey": {
      "Value": "server.npcRoles.Adventurer.name",
      "Description": "Translation key for NPC name display"
    }
  },
  "StartState": "Idle",
  "DefaultNPCAttitude": "Ignore",
  "DefaultPlayerAttitude": "Neutral",
  "Appearance": "Kweebec_Rootling",
  "MaxHealth": 50,
  "IsMemory": true,
  "MemoriesCategory": "Adventurer",
  "NameTranslationKey": { "Compute": "NameTranslationKey" },
  "DisableDamageGroups": [ "Self" ],
  "CombatConfig": {
    "EntityEffect": "Immunity_Environmental"
  },
  "BusyStates": [ "$Interaction" ],
  "Invulnerable": true,
  "KnockbackScale": 0.5,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 8,
      "Gravity": 10,
      "RunThreshold": 0.3,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10
    }
  ],
  "Instructions": [
    {
      "Instructions": [
        {
          "$Comment": "Idle state - no player nearby",
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "$Comment": "Wave at player when they approach",
              "ActionsBlocking": true,
              "Sensor": {
                "Type": "Player",
                "Range": 8
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Wave"
                },
                {
                  "Type": "State",
                  "State": "Watching"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "BodyMotion": {
                "Type": "Nothing"
              }
            }
          ]
        },
        {
          "$Comment": "Watching state - player is nearby, just watch them",
          "Sensor": {
            "Type": "State",
            "State": "Watching"
          },
          "Instructions": [
            {
              "$Comment": "Watch nearby players with head",
              "Continue": true,
              "Sensor": {
                "Type": "Player",
                "Range": 12
              },
              "HeadMotion": {
                "Type": "Watch"
              }
            },
            {
              "$Comment": "Adventurer-specific: notice nearby hostile creatures, mirroring the real Trork combat AI's own threat sensor (Type: Mob, Prioritiser: Attitude/Hostile) - feeds npc-ai-stack's ThreatMemory so the AI can react to it in conversation. LockOnTarget makes the found hostile the locked \"Target\" the chase/attack nodes below react to.",
              "Continue": true,
              "Sensor": {
                "Type": "Mob",
                "Range": 30,
                "GetPlayers": false,
                "GetNPCs": true,
                "LockOnTarget": true,
                "Prioritiser": {
                  "Type": "Attitude",
                  "AttitudesByPriority": [ "Hostile" ]
                }
              },
              "Actions": [
                {
                  "Type": "NoteNearbyThreat"
                }
              ]
            },
            {
              "$Comment": "Clear wave animation after delay",
              "Continue": true,
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [ 2, 2 ],
                  "Action": {
                    "Type": "PlayAnimation",
                    "Slot": "Status"
                  }
                }
              ]
            },
            {
              "$Comment": "Return to Idle when player leaves (clear animation first)",
              "Sensor": {
                "Type": "Not",
                "Sensor": {
                  "Type": "Player",
                  "Range": 12
                }
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status"
                },
                {
                  "Type": "State",
                  "State": "Idle"
                }
              ]
            },
            {
              "$Comment": "Companion combat, melee range: once tamed, if a hostile is locked as Target and close enough, attack it. Real \"Attack\" action (confirmed via disassembly of BuilderActionAttack, and via real shipped usage in Component_Instruction_Attack_Sequence_Spirit.json/Component_Instruction_Intelligent_Idle_Goblin.json) - \"Root_NPC_Attack_Melee\" is the same generic melee attack pattern the real, shipped Tamed_Cow.json uses, not a made-up interaction id. This node has no Continue, so it takes priority over chasing/following below whenever it matches.",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  { "Type": "IsCompanion" },
                  { "Type": "Target", "Range": 3 }
                ]
              },
              "Actions": [
                {
                  "Type": "Attack",
                  "Attack": "Root_NPC_Attack_Melee",
                  "AttackPauseRange": [ 1, 2 ]
                }
              ],
              "HeadMotion": {
                "Type": "Watch"
              },
              "BodyMotion": {
                "Type": "Nothing"
              }
            },
            {
              "$Comment": "Companion combat, chase: hostile locked as Target but not yet in melee range - close the distance. Takes priority over following the player (no Continue) whenever a hostile is being chased.",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  { "Type": "IsCompanion" },
                  { "Type": "Target", "Range": 20 }
                ]
              },
              "BodyMotion": {
                "Type": "Seek",
                "RelativeSpeed": 1,
                "StopDistance": 2,
                "RelaxedMoveConstraints": false
              }
            },
            {
              "$Comment": "Companion mode: once tamed, seek toward the nearest player instead of standing still (no hostile currently being fought/chased - see the two nodes above, which take priority). The Seek/MaintainDistance BodyMotion types are real, shipped engine functionality (confirmed via disassembly and via the real Template_Livestock.json's own tamed-animal follow behavior), not custom pathfinding code. v1 simplification: follows the nearest player, not specifically its owner - correct for solo/small-group testing, would need real owner-specific entity filtering for a populated multiplayer world (see CompanionState.java's javadoc)",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  { "Type": "IsCompanion" },
                  { "Type": "Player", "Range": 30 }
                ]
              },
              "BodyMotion": {
                "Type": "Seek",
                "RelativeSpeed": 0.9,
                "StopDistance": 3,
                "RelaxedMoveConstraints": false
              }
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "BodyMotion": {
                "Type": "Nothing"
              }
            }
          ]
        },
        {
          "$Comment": "Interaction state - look at the talking player",
          "Sensor": {
            "Type": "State",
            "State": "$Interaction"
          },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": {
                "Type": "Target",
                "Range": 10
              },
              "HeadMotion": {
                "Type": "Watch"
              }
            },
            {
              "$Comment": "Return to Watching after interaction ends",
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [ 1, 1 ],
                  "Action": {
                    "Type": "Sequence",
                    "Actions": [
                      {
                        "Type": "ReleaseTarget"
                      },
                      {
                        "Type": "State",
                        "State": "Watching"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "InteractionInstruction": {
    "Instructions": [
      {
        "Sensor": {
          "Type": "Not",
          "Sensor": {
            "Type": "CanInteract",
            "ViewSector": 180
          }
        },
        "Actions": [
          {
            "Type": "SetInteractable",
            "Interactable": false
          }
        ]
      },
      {
        "Continue": true,
        "Sensor": {
          "Type": "Any"
        },
        "Actions": [
          {
            "Type": "SetInteractable",
            "Interactable": true,
            "Hint": "server.interactionHints.trade"
          }
        ]
      },
      {
        "Sensor": {
          "Type": "HasInteracted"
        },
        "Instructions": [
          {
            "Sensor": {
              "Type": "Not",
              "Sensor": {
                "Type": "State",
                "State": "$Interaction"
              }
            },
            "Actions": [
              {
                "Type": "LockOnInteractionTarget"
              },
              {
                "Type": "TalkToAI",
                "DisplayName": "Wandering Adventurer",
                "AIRole": "adventurer"
              },
              {
                "Type": "State",
                "State": "$Interaction"
              }
            ]
          }
        ]
      }
    ]
  }
}
