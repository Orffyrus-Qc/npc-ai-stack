{
  "Type": "Generic",
  "Parameters": {
    "NameTranslationKey": {
      "Value": "server.npcRoles.Merchant_Oskar.name",
      "Description": "Translation key for NPC name display"
    }
  },
  "StartState": "Idle",
  "DefaultNPCAttitude": "Ignore",
  "DefaultPlayerAttitude": "Neutral",
  "Appearance": "Klops_Merchant",
  "MaxHealth": 50,
  "IsMemory": true,
  "MemoriesCategory": "Merchant_Oskar",
  "NameTranslationKey": { "Compute": "NameTranslationKey" },
  "DisableDamageGroups": [ "Self" ],
  "CombatConfig": {
    "EntityEffect": "Immunity_Environmental"
  },
  "BusyStates": [ "$Interaction" ],
  "Invulnerable": true,
  "KnockbackScale": 0.5,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 8,
      "Gravity": 10,
      "RunThreshold": 0.3,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10
    }
  ],
  "Instructions": [
    {
      "Instructions": [
        {
          "$Comment": "Idle state - no player nearby",
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "$Comment": "Wave at player when they approach",
              "ActionsBlocking": true,
              "Sensor": {
                "Type": "Player",
                "Range": 8
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Wave"
                },
                {
                  "Type": "State",
                  "State": "Watching"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "BodyMotion": {
                "Type": "Nothing"
              }
            }
          ]
        },
        {
          "$Comment": "Watching state - player is nearby, just watch them",
          "Sensor": {
            "Type": "State",
            "State": "Watching"
          },
          "Instructions": [
            {
              "$Comment": "Watch nearby players with head",
              "Continue": true,
              "Sensor": {
                "Type": "Player",
                "Range": 12
              },
              "HeadMotion": {
                "Type": "Watch"
              }
            },
            {
              "$Comment": "\"AI process message waiting\" indicator: a floating thought-bubble particle above this NPC's head while npc-ai-stack is waiting on a real orchestrator round trip - a reply that just appears in chat with zero visual buildup reads as unnaturally instant. Real, shipped particle asset (Server/Particles/NPC/Emotions/Question_Subtle.particlesystem); Offset [0, 2.1, 0] matches the real, shipped usage in Trork's own Alerted-state SpawnParticles call. \"Once\": true so this fires once per wait, not every tick for the whole duration - see IsAwaitingReplySensor.java/AwaitingReplyState.java.",
              "Continue": true,
              "Sensor": {
                "Type": "IsAwaitingReply",
                "Once": true
              },
              "Actions": [
                {
                  "Type": "SpawnParticles",
                  "Offset": [ 0, 2.1, 0 ],
                  "ParticleSystem": "Question_Subtle"
                }
              ]
            },
            {
              "$Comment": "Open the real barter shop if npc-ai-stack's AI decided OPEN_SHOP. Lives here (Watching), not $Interaction - $Interaction only lasts ~1 tick-second before Timeout/ReleaseTarget ends it, but the real LLM round trip that decides OPEN_SHOP routinely takes longer than that, so a check placed in $Interaction alone misses its window almost every time (confirmed live). Watching is where a conversation actually spends its time.",
              "Continue": true,
              "Sensor": {
                "Type": "Player",
                "Range": 12
              },
              "Actions": [
                {
                  "Type": "OpenShopIfRequested",
                  "ShopId": "Klops_Merchant"
                }
              ]
            },
            {
              "$Comment": "Real, shipped 'Damage' sensor Type (Combat: true) - confirmed via disassembly of SensorDamage/BuilderSensorDamage AND via its real usage in Server/NPC/Roles/_Core/Components/Steps/Component_Instruction_Damage_Check.json (the neutral Kweebec's own Panic trigger). Reports a player physically attacking this NPC as a real outcome (personality.py's player_attacked_npc) - see NoteAttackedByPlayerAction.java. Not yet live-confirmed against a real attack (this NPC role sets Invulnerable:true; grounded in PlayerDamageFilterSystem's own pattern of cancelling damage via a flag on an event that still fires, rather than suppressing the event entirely, but that's inference from disassembly, not a live test).",
              "Continue": true,
              "Sensor": {
                "Type": "Damage",
                "Combat": true
              },
              "Actions": [
                {
                  "Type": "NoteAttackedByPlayer",
                  "AIRole": "merchant"
                }
              ]
            },
            {
              "$Comment": "Clear wave animation after delay",
              "Continue": true,
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [ 2, 2 ],
                  "Action": {
                    "Type": "PlayAnimation",
                    "Slot": "Status"
                  }
                }
              ]
            },
            {
              "$Comment": "Return to Idle when player leaves (clear animation first)",
              "Sensor": {
                "Type": "Not",
                "Sensor": {
                  "Type": "Player",
                  "Range": 12
                }
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status"
                },
                {
                  "Type": "State",
                  "State": "Idle"
                }
              ]
            },
            {
              "$Comment": "Guiding: the AI decided OFFER_GUIDE (see llm_client.py) and GuideState.startGuiding() was called - walk toward NearbyLandmarks.closestPosition() until SeekLandmarkSensor reports arrival (it stops matching automatically). Takes priority over merely following the player (no Continue).",
              "Sensor": {
                "Type": "SeekLandmark"
              },
              "BodyMotion": {
                "Type": "Seek",
                "RelativeSpeed": 1,
                "StopDistance": 2,
                "RelaxedMoveConstraints": false
              }
            },
            {
              "$Comment": "Companion mode: once tamed, seek toward the nearest player instead of standing still (not actively guiding - see the node above, which takes priority). The Seek/MaintainDistance BodyMotion types are real, shipped engine functionality (confirmed via disassembly and via the real Template_Livestock.json's own tamed-animal follow behavior), not custom pathfinding code. v1 simplification: follows the nearest player, not specifically its owner - correct for solo/small-group testing, would need real owner-specific entity filtering for a populated multiplayer world (see CompanionState.java's javadoc)",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  { "Type": "IsCompanion" },
                  { "Type": "Player", "Range": 30 }
                ]
              },
              "BodyMotion": {
                "Type": "Seek",
                "RelativeSpeed": 0.9,
                "StopDistance": 3,
                "RelaxedMoveConstraints": false
              }
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "BodyMotion": {
                "Type": "Nothing"
              }
            }
          ]
        },
        {
          "$Comment": "Interaction state - look at the talking player",
          "Sensor": {
            "Type": "State",
            "State": "$Interaction"
          },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": {
                "Type": "Target",
                "Range": 10
              },
              "HeadMotion": {
                "Type": "Watch"
              }
            },
            {
              "$Comment": "Same \"AI process message waiting\" indicator as the Watching state above - the very start of a click-triggered conversation's wait happens here, in $Interaction, before the ~1s Timeout below reverts to Watching.",
              "Continue": true,
              "Sensor": {
                "Type": "IsAwaitingReply",
                "Once": true
              },
              "Actions": [
                {
                  "Type": "SpawnParticles",
                  "Offset": [ 0, 2.1, 0 ],
                  "ParticleSystem": "Question_Subtle"
                }
              ]
            },
            {
              "$Comment": "Keep following even while starting a conversation - $Interaction only lasts ~1s before the Timeout below returns to Watching, but without this an established companion visibly freezes for that second every time the player clicks to talk. Continue:true is required here so the Timeout node below still runs every tick regardless of whether this one matches - without it, a nearby companion would get stuck in $Interaction forever.",
              "Continue": true,
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  { "Type": "IsCompanion" },
                  { "Type": "Player", "Range": 30 }
                ]
              },
              "BodyMotion": {
                "Type": "Seek",
                "RelativeSpeed": 0.9,
                "StopDistance": 3,
                "RelaxedMoveConstraints": false
              }
            },
            {
              "$Comment": "Return to Watching after interaction ends",
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [ 1, 1 ],
                  "Action": {
                    "Type": "Sequence",
                    "Actions": [
                      {
                        "Type": "ReleaseTarget"
                      },
                      {
                        "Type": "State",
                        "State": "Watching"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "InteractionInstruction": {
    "Instructions": [
      {
        "Sensor": {
          "Type": "Not",
          "Sensor": {
            "Type": "CanInteract",
            "ViewSector": 180
          }
        },
        "Actions": [
          {
            "Type": "SetInteractable",
            "Interactable": false
          }
        ]
      },
      {
        "Continue": true,
        "Sensor": {
          "Type": "Any"
        },
        "Actions": [
          {
            "Type": "SetInteractable",
            "Interactable": true,
            "Hint": "server.interactionHints.trade"
          }
        ]
      },
      {
        "Sensor": {
          "Type": "HasInteracted"
        },
        "Instructions": [
          {
            "Sensor": {
              "Type": "Not",
              "Sensor": {
                "Type": "State",
                "State": "$Interaction"
              }
            },
            "Actions": [
              {
                "Type": "LockOnInteractionTarget"
              },
              {
                "Type": "TalkToAI",
                "DisplayName": "Oskar the Trader",
                "AIRole": "merchant"
              },
              {
                "Type": "State",
                "State": "$Interaction"
              }
            ]
          }
        ]
      }
    ]
  }
}
